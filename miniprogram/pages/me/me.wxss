.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 34rpx 0 6rpx;
}
.avatar-wrap {
  position: relative;
  width: 148rpx;
  height: 148rpx;
}
.avatar-frame {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f4eadc;
  border: 6rpx solid rgba(255, 255, 255, 0.96);
  box-shadow: 0 0 0 2rpx rgba(200, 134, 43, 0.22), 0 12rpx 24rpx rgba(92, 62, 27, 0.14);
  box-sizing: border-box;
  overflow: hidden;
}
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}
.avatar-btn {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 3;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: transparent;
  opacity: 0;
  font-size: 0;
  line-height: normal;
}
.avatar-btn::after {
  border: none;
}
.avatar-badge {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  z-index: 2;
  width: 42rpx;
  height: 42rpx;
  background: #fff8ed;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 5rpx 14rpx rgba(70, 44, 18, 0.16);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}
.badge-icon {
  width: 24rpx;
  height: 24rpx;
}
.nickname-input {
  margin-top: 16rpx;
  width: 320rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  min-height: 48rpx;
}

.stat-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 28rpx 32rpx 0;
}
.stat-block {
  width: 48.5%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 28rpx;
}
.stat-label {
  font-size: 24rpx;
  color: var(--muted);
}
.stat-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 600;
}
.stat-value.small {
  font-size: 26rpx;
}
.unit {
  font-size: 22rpx;
  color: var(--muted);
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.history {
  padding: 20rpx 32rpx 0;
}
.empty {
  padding: 64rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--muted);
}
.history-list {
  display: flex;
  flex-direction: column;
}
.history-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 24rpx;
}
.hi-emoji {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}
.hi-main {
  flex: 1;
  min-width: 0;
}
.hi-top {
  display: flex;
  align-items: center;
}
.hi-dur {
  font-size: 28rpx;
  font-weight: 500;
}
.hi-tag {
  color: #fff;
  font-size: 20rpx;
  margin-left: 12rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
}
.hi-date {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--muted);
}
.hi-del {
  padding: 12rpx;
  font-size: 32rpx;
  color: var(--muted);
}

.history-item--failed {
  border: 2rpx solid var(--destructive);
}
.hi-failed {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--destructive);
}
.hi-resave {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  color: #fff;
  background: var(--destructive);
  border-radius: 999rpx;
}
